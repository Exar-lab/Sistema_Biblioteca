# Oracle SQLAlchemy URL (thin mode)
DATABASE_URL=oracle+oracledb://USERNAME:PASSWORD@HOST:1521/?service_name=FREEPDB1

# Optional SQLAlchemy SQL logging
SQLALCHEMY_ECHO=false

# JWT settings for /api/v1/auth/login and Bearer-token protected endpoints.
# Generate a real secret with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
